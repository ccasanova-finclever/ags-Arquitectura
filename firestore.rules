rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null
        && request.auth.token.email.matches('.*@agsnegocios[.]cl');
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role;
    }

    // ---- Usuarios ------------------------------------------------
    // Auto-provisión al primer login: solo con el rol del seed
    // (hardcodeado aquí) o como 'lectura'. Cambios de rol: superadmin.
    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.token.email == email
        && (
          (email == 'ccasanova@agsnegocios.cl'
            && request.resource.data.role == 'superadmin')
          || (email == 'fernando.colchero@agsnegocios.cl'
            && request.resource.data.role == 'director')
          || request.resource.data.role == 'lectura'
        );
      allow update, delete: if isSignedIn() && userRole() == 'superadmin';
    }

    // ---- Anteproyectos -------------------------------------------
    match /projects/{pid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && userRole() in ['superadmin', 'director', 'arquitecto'];
      allow delete: if isSignedIn()
        && userRole() in ['superadmin', 'director'];

      match /{sub=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
          && userRole() in ['superadmin', 'director', 'arquitecto'];
      }
    }

    // Todo lo demás: denegado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
